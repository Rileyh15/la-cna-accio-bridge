# ══════════════════════════════════════════════════════════════════════
# LA CNA Registry Bridge — Environment Variables
#
# COPY this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ══════════════════════════════════════════════════════════════════════

# Accio Data API credentials
ACCIO_API_BASE_URL=https://your-instance.acciodata.com
ACCIO_API_ACCOUNT=your_account_name
ACCIO_API_USERNAME=your_api_username
ACCIO_API_PASSWORD=your_api_password
ACCIO_API_MODE=PROD

# Webhook authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
WEBHOOK_SECRET=replace_with_64_char_hex_string

# Operational tuning
MAX_CONCURRENT_LOOKUPS=3
HTTP_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0
PORT=8080
